# NetLogic local environment — loaded by netlogic.py at launch.
# Values here are NON-SECRET (Clerk issuer is public). Real secrets (JWT/admin)
# are auto-generated into ~/.netlogic/secrets.json by `netlogic --gui`.

# Clerk human-login verification (backend verifies session JWTs via this issuer's JWKS).
NETLOGIC_OIDC_ISSUER=https://trusty-humpback-45.clerk.accounts.dev

# Optional: PostgreSQL for persistent users/orgs/api-keys. Leave unset to run
# in-memory. Uncomment after `docker compose up -d postgres`.
# NETLOGIC_DATABASE_URL=postgresql://netlogic:netlogic@localhost:5432/netlogic
