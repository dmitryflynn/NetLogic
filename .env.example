# NetLogic API — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────────

# Secret used to sign/verify JWTs. Must be at least 32 characters.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
NETLOGIC_JWT_SECRET=change-me-use-a-long-random-string-here

# Admin API key used to create org API keys via POST /auth/keys.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
NETLOGIC_ADMIN_KEY=change-me-admin-key

# ── AI Layer (Phase 4) ────────────────────────────────────────────────────────

# Default AI provider for AI analysis when a scan does not supply one.
# Supported: openrouter, openai, anthropic, kimi, qwen, groq, gemini, ollama, custom
NETLOGIC_AI_PROVIDER=openrouter

# API key for the selected provider. Provider-specific env vars also work:
# OPENROUTER_API_KEY, OPENAI_API_KEY, ANTHROPIC_API_KEY, KIMI_API_KEY,
# MOONSHOT_API_KEY, DASHSCOPE_API_KEY, GOOGLE_API_KEY, or GEMINI_API_KEY.
NETLOGIC_AI_API_KEY=

# Model id for AI analysis. For OpenRouter, paste the exact provider/model id.
NETLOGIC_AI_MODEL=

# Required only when NETLOGIC_AI_PROVIDER=custom.
NETLOGIC_AI_BASE_URL=

# ── Human logins via Clerk (OIDC) ─────────────────────────────────────────────
# Backend verifies Clerk-issued session JWTs against Clerk's JWKS. These are all
# NON-SECRET (the Clerk *secret* key is never needed here — JWKS is public).
# Set the issuer to enable; leave blank to disable the OIDC path entirely.
#
# Issuer = your Clerk Frontend API URL (Dashboard → API keys → Frontend API URL).
NETLOGIC_OIDC_ISSUER=https://trusty-humpback-45.clerk.accounts.dev
# JWKS URL — defaults to {issuer}/.well-known/jwks.json if left blank.
NETLOGIC_OIDC_JWKS_URL=
# Optional: enforce the token audience (Clerk's default session token has none).
NETLOGIC_OIDC_AUDIENCE=
# Optional: comma-separated allowed `azp` origins (Clerk stamps the request origin).
# Example: https://app.netlogic.io,http://localhost:8000
NETLOGIC_OIDC_AUTHORIZED_PARTIES=
# Optional: fallback org for users without an active Clerk Organization.
# Leave blank to give each such user an isolated personal workspace (their sub).
NETLOGIC_OIDC_DEFAULT_ORG=

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# System of record for users, orgs, memberships, API keys, and audit. OPTIONAL:
# leave blank to run fully in-memory (local/desktop). Set it to enable persistent
# multi-tenant SaaS auth — migrations apply automatically at startup.
# Local dev: `docker compose up -d postgres` then use the URL below.
# NETLOGIC_DATABASE_URL=postgresql://netlogic:netlogic@localhost:5432/netlogic
NETLOGIC_DATABASE_URL=

# ── Secret sealing (per-org API keys at rest) ─────────────────────────────────
# Master key that encrypts each org's LLM API keys before storage. REQUIRED when
# NETLOGIC_DATABASE_URL is set — the server refuses (503) to store a key without
# it, so credentials are never persisted in plaintext. Generate:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
NETLOGIC_SECRETS_KEY=

# Frontend (dashboard) — Vite reads this at build time. NON-SECRET (publishable).
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_dHJ1c3R5LWh1bXBiYWNrLTQ1LmNsZXJrLmFjY291bnRzLmRldiQ

# ── Optional ──────────────────────────────────────────────────────────────────

# Comma-separated allowed CORS origins. Use * to allow all (dev only).
# Example: https://app.example.com,https://admin.example.com
NETLOGIC_CORS_ORIGINS=http://localhost:5173

# Directory where scan results are stored (default: ~/.netlogic/scans)
NETLOGIC_SCANS_DIR=

# API server host and port
NETLOGIC_HOST=0.0.0.0
NETLOGIC_PORT=8000

# Set to 1 to suppress the auto-open browser on startup (always set in Docker)
NETLOGIC_NO_BROWSER=0

# JWT token expiry in seconds (default: 3600 = 1 hour)
NETLOGIC_JWT_EXPIRY=3600
