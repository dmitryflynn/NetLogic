{
  "name": "netlogic",
  "version": "2.0.0",
  "description": "Attack Surface Mapper & Vulnerability Correlator",
  "author": "Dmitry Flynn",
  "main": "electron/main.js",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win --x64",
    "build:all": "electron-builder --win --mac --linux",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "com.netlogic.app",
    "productName": "NetLogic",
    "copyright": "Copyright © 2026 Dmitry Flynn",
    "icon": "build/netlogic.ico",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "asarUnpack": [
      "netlogic.py",
      "src/**/*"
    ],
    "files": [
      "electron/**/*",
      "renderer/**/*",
      "src/**/*",
      "netlogic.py",
      "build/netlogic.png",
      "build/netlogic.ico"
    ],
    "extraResources": [
      {
        "from": "python_dist/",
        "to": "python_dist/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker",
      "icon": "build/netlogic.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "build/netlogic.ico",
      "uninstallerIcon": "build/netlogic.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NetLogic",
      "license": "LICENSE.txt",
      "runAfterFinish": true
    },
    "portable": {
      "artifactName": "NetLogic-${version}-portable.exe"
    }
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1"
  }
}
